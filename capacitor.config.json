{
  "appId": "com.farazcode.editor",
  "appName": "Faraz Code Editor",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1e1e1e",
      "showSpinner": false
    }
  }
}
