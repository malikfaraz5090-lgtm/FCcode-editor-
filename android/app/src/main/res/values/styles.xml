<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <!-- Base App Theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:statusBarColor">#1e1e1e</item>
        <item name="android:navigationBarColor">#1e1e1e</item>
        <item name="android:windowBackground">#1e1e1e</item>
        <item name="colorPrimary">#007acc</item>
        <item name="colorPrimaryDark">#005a9e</item>
        <item name="colorAccent">#4ec9b0</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">#1e1e1e</item>
        <item name="android:navigationBarColor">#1e1e1e</item>
    </style>
    
</resources>
